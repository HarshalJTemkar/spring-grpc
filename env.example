# Database 
DB_HOST=localhost 
DB_PORT=5432 
DB_NAME=oauthdb 
DB_USER=oauthuser 
DB_PASSWORD=oauthpass 
 
# Redis 
REDIS_HOST=localhost 
REDIS_PORT=6379 
 
# Vault 
VAULT_ADDR=http://localhost:8200 
VAULT_TOKEN=myroot 
 
# JWT 
JWT_SECRET=change-me-in-production-use-256-bit-secret 
JWT_EXPIRATION_MS=3600000 
JWT_REFRESH_EXPIRATION_MS=86400000 
 
# gRPC Server 
GRPC_SERVER_PORT=9090 
 
# GraphQL Gateway 
SERVER_PORT=8080 
GRPC_CLIENT_ADDRESS=static://localhost:9090 
